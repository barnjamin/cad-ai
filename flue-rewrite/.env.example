# Anthropic direct access. Optional when using OpenRouter instead.
ANTHROPIC_API_KEY=""

# Preferred OpenRouter key name. The agent also accepts OPENROUTER_KEY for compatibility.
OPENROUTER_API_KEY=""

# Optional explicit model override.
# - Anthropic direct: anthropic/claude-sonnet-4-6
# - OpenRouter: openrouter/moonshotai/kimi-k2.6
FLUE_MODEL_ID=""

# Optional OpenRouter-only model shortcut.
# If FLUE_MODEL_ID is empty and an OpenRouter key is present,
# the agent uses this value, defaulting to openrouter/moonshotai/kimi-k2.6.
OPENROUTER_MODEL_ID=""

# Optional local llama.cpp endpoint used by scripts/run-llama-openscad.ts
VITE_LLAMACPP_BASE_URL="http://192.168.4.220:8080/"
LLAMACPP_MODEL_ID=""
LLAMACPP_MAX_TOKENS="1024"
